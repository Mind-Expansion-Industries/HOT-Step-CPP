# ace-server configuration
# Point these to your acestep.cpp installation
ACESTEPCPP_EXE=D:\path\to\acestep.cpp\build\Release\ace-server.exe
ACESTEPCPP_MODELS=D:\path\to\acestep.cpp\models
ACESTEPCPP_ADAPTERS=D:\path\to\acestep.cpp\adapters
ACESTEPCPP_PORT=8085
ACESTEPCPP_HOST=127.0.0.1

# Node.js server
SERVER_PORT=3001
DATA_DIR=./server/data

# Dev mode (Vite)
VITE_PORT=3000
VITE_HOST=0.0.0.0
